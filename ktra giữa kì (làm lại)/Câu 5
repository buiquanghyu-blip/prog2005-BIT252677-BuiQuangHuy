class Flower:
    def __init__(self, color):
        self.__color = color   

    def get_color(self):
        return self.__color

    def set_color(self, color):
        self.__color = color


hoa = Flower("Đỏ")

print("Màu ban đầu:", hoa.get_color())

hoa.set_color("Vàng")

print("Màu sau khi đổi:", hoa.get_color())
